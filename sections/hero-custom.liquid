{%- liquid
  assign heading = section.settings.heading
  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link
  assign hero-billboard_image = section.settings['hero-image']['hero-image']
  assign text_color = section.settings.text_color
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
  assign align_mobile = section.settings.align_mobile
  assign align_desktop = section.settings.align_desktop
  assign vertical_position = section.settings.vertical_position

  if section.index == 1
    assign image_loading = 'eager'
    assign image_priority = 'high'
  else
    assign image_loading = 'lazy'
    assign image_priority = 'auto'
  endif
-%}

<section
  class="hero-billboard"
  id="hero-billboard-{{ section.id }}"
  aria-label="{{ heading | strip_html | default: 'hero-billboard' }}"
>
  <style>
    #hero-billboard-{{ section.id }} {
      --hero-billboard-text-color: {{ text_color }};
      --hero-billboard-overlay-opacity: {{ overlay_opacity }};
      --hero-billboard-height: {{ section.settings.height_mobile }}vh;
    }
    @media screen and (min-width: 768px) {
      #hero-billboard-{{ section.id }} {
        --hero-billboard-height: {{ section.settings.height_tablet }}vh;
      }
    }
    @media screen and (min-width: 1024px) {
      #hero-billboard-{{ section.id }} {
        --hero-billboard-height: {{ section.settings.height_desktop }}vh;
      }
    }
  </style>

  <div class="hero-billboard__media">
    <div class="hero-billboard__picture">
      {% if hero-billboard_image != blank %}
        {{
          hero-billboard_image
          | image_url: width: 2400
          | image_tag:
            class: 'hero-billboard__image',
            widths: '480,750,1024,1500,1920,2400',
            sizes: '100vw',
            loading: image_loading,
            fetchpriority: image_priority,
            alt: hero-billboard_image.alt
        }}
      {% else %}
        <img
          class="hero-billboard__image"
          src="{{ 'hero-image.webp' | asset_url }}"
          alt="{{ heading | escape }}"
          width="1920"
          height="1080"
          loading="lazy"
        >
      {% endif %}
    </div>

    {%- if overlay_opacity > 0 -%}
      <div class="hero-billboard__scrim" aria-hidden="true"></div>
    {%- endif -%}

    <div
      class="
        hero-billboard__content
        hero-billboard__content--align-{{ align_mobile }}
        hero-billboard__content--v-{{ vertical_position }}
        hero-billboard__content--desktop-align-{{ align_desktop }}
      "
    >
      {%- if heading != blank -%}
        <h2 class="hero-billboard__heading">{{ heading }}</h2>
      {%- endif -%}
      {%- if button_label != blank -%}
        <a
          {% if button_link != blank %}
            href="{{ button_link }}"
          {% else %}
            role="link" aria-disabled="true"
          {% endif %}
          class="hero-billboard__button"
        >
          {{ button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-billboard {
    --hero-billboard-text-color: #ffffff;
    --hero-billboard-overlay-opacity: 0;
    --hero-billboard-height: 100vh;
    position: relative;
    width: 100%;
  }

  .hero-billboard__media {
    position: relative;
    width: 100%;
    height: var(--hero-billboard-height);
    min-height: 420px;
    overflow: hidden;
  }

  .hero-billboard__picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-billboard__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-billboard__scrim {
    position: absolute;
    inset: 0;
    background-color: #000000;
    opacity: var(--hero-billboard-overlay-opacity);
    pointer-events: none;
  }

  .hero-billboard__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    text-align: center;
    padding: 8% 6% 14%;
    gap: 24px;
    color: var(--hero-billboard-text-color);
  }

  .hero-billboard__content--v-top {
    justify-content: flex-start;
    padding-top: 14%;
  }

  .hero-billboard__content--v-center {
    justify-content: center;
  }

  .hero-billboard__content--v-bottom {
    justify-content: flex-end;
  }

  .hero-billboard__content--align-left {
    align-items: flex-start;
    text-align: left;
  }

  .hero-billboard__content--align-center {
    align-items: center;
    text-align: center;
  }

  .hero-billboard__content--align-right {
    align-items: flex-end;
    text-align: right;
  }

  .hero-billboard__heading {
    margin: 0;
    color: currentColor;
    font-weight: 700;
    font-size: clamp(1.75rem, 8vw, 2.5rem);
    line-height: 1.25;
    letter-spacing: 0.01em;
    max-width: 22ch;
    text-wrap: balance;
  }

  .hero-billboard__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #ffffff;
    color: #1a1a1a;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    padding: 0.9em 1.8em;
    border: 1px solid #ffffff;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .hero-billboard__button:hover,
  .hero-billboard__button:focus-visible {
    background-color: transparent;
    color: #ffffff;
  }

  .hero-billboard__button:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 3px;
  }

  .hero-billboard__image--placeholder {
    object-fit: contain;
    background-color: #f4f4f4;
  }

  /* Tablet */
  @media screen and (min-width: 768px) {
    .hero-billboard__content {
      padding: 6% 8% 16%;
      gap: 28px;
    }

    .hero-billboard__content--desktop-align-left {
      align-items: flex-start;
      text-align: left;
    }

    .hero-billboard__content--desktop-align-center {
      align-items: center;
      text-align: center;
    }

    .hero-billboard__content--desktop-align-right {
      align-items: flex-end;
      text-align: right;
    }

    .hero-billboard__heading {
      font-size: clamp(2.25rem, 6vw, 3rem);
      max-width: 20ch;
    }

    .hero-billboard__button {
      font-size: 0.8125rem;
      padding: 1em 2em;
    }
  }

  /* Desktop / large screens */
  @media screen and (min-width: 1024px) {
    .hero-billboard__content {
      padding: 4% 8% 8%;
      gap: 32px;
    }

    .hero-billboard__heading {
      font-size: clamp(2.5rem, 4vw, 3.5rem);
      max-width: 18ch;
    }

    .hero-billboard__button {
      font-size: 0.875rem;
      padding: 1.05em 2.2em;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "shopify-section--hero-billboard",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "hero-image",
      "label": "Hero image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Make Your Fashion Look Swanky."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "align_mobile",
      "label": "Content alignment (mobile)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "align_desktop",
      "label": "Content alignment (tablet & desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_position",
      "label": "Content vertical position",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "bottom"
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Section height, mobile (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 100
    },
    {
      "type": "range",
      "id": "height_tablet",
      "label": "Section height, tablet (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 100
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Section height, desktop (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "category": "Custom sections"
    }
  ]
}
{% endschema %}
